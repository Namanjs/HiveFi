# HiveFi Specialist Node Configuration

# ==========================================
# Core Identity (Required)
# ==========================================
# MODEL_ID — the model name (e.g. llama3, mistral, codellama for Ollama or a HF model path)
MODEL_ID=llama3

# NICHE — what this specialist handles (SQL, PYTHON, FRONTEND, DESIGN etc)
NICHE=SQL

# WALLET — the developer's wallet address that receives USDC payments
WALLET=0xYourWalletAddressHere

# PRICE_PER_QUERY — price in USDC this specialist charges per call
PRICE_PER_QUERY=0.05

# ==========================================
# Backend Configuration (Required)
# ==========================================
# BACKEND — either 'ollama' or 'huggingface'
BACKEND=ollama

# OLLAMA_BASE_URL — defaults to http://localhost:11434 if not set
OLLAMA_BASE_URL=http://localhost:11434

# HUGGINGFACE_API_KEY — required only if BACKEND is huggingface
HUGGINGFACE_API_KEY=

# ==========================================
# Advanced Configuration (Optional)
# ==========================================
# SYSTEM_PROMPT — behavioral instruction for the model
SYSTEM_PROMPT="You are an expert SQL specialist. Output only valid SQL queries with no explanation or conversational text."

# OLLAMA_TIMEOUT_MS — timeout in milliseconds (default 60000). Increase if your local model takes longer to load.
OLLAMA_TIMEOUT_MS=60000

# HF_TIMEOUT_MS — timeout in milliseconds (default 60000). Increase if HuggingFace 503 cold starts take longer.
HF_TIMEOUT_MS=60000

# AUTH_SECRET — Auth Secret for communication with Orchestrator
AUTH_SECRET=my-super-secret-auth-key

# PORT — defaults to 4000
PORT=4000
