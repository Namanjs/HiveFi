# HiveFi Backend Environment Settings
PORT=3001

# Web3 Private Keys (WARNING: Use testnet-only accounts. Never reuse mainnet keys)
# Wallet A: Orchestrator
ORCHESTRATOR_PK=0xYOUR_ORCHESTRATOR_PRIVATE_KEY_HERE
# Wallet B: Specialist
SPECIALIST_PK=0xYOUR_SPECIALIST_PRIVATE_KEY_HERE

# Contract Addresses (Deploy via Deploy page or Remix IDE to Sepolia)
MOCK_USDC_ADDRESS=0xYOUR_MOCK_USDC_ADDRESS_HERE
HIVE_REGISTRY_ADDRESS=0xYOUR_HIVE_REGISTRY_ADDRESS_HERE

# RPC Endpoint (Ethereum Sepolia — yes the var name says BASE but we use Ethereum Sepolia)
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Groq API Key (Required)
GROQ_API_KEY=your_groq_api_key_here

# CORS: Comma-separated allowed origins (default: localhost:5173,localhost:3000)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth Secret for Specialist Communication
AUTH_SECRET=my-super-secret-auth-key
